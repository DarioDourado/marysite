# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_CALENDAR_ID: The ID of the Google Calendar to use for bookings.
GOOGLE_CALENDAR_ID="primary"

# GOOGLE_SERVICE_ACCOUNT_EMAIL: The email of the Google Service Account.
GOOGLE_SERVICE_ACCOUNT_EMAIL=""

# GOOGLE_PRIVATE_KEY: The private key of the Google Service Account.
GOOGLE_PRIVATE_KEY=""
